    { device = "tank/media";
      fsType = "zfs";
    };

  fileSystems."/boot" = {
    device = "/dev/disk/by-uuid/D147-EA04";
    fsType = "vfat";
    options = [
      "noatime"
      "nodiratime"
      "flush"
      "fmask=0077" "dmask=0077"
    ];
  };

