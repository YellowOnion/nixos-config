  fileSystems."/mnt" = {
    device = "/dev/disk/by-uuid/fd588396-85fe-49b0-a6bf-870008f59a60";
    fsType = "xfs";
    options = [ "noatime" ];
  };

  swapDevices =
    [ { device = "/dev/disk/by-uuid/c10846b3-76c3-40e9-bd4e-fdf2fb127e0e"; }
